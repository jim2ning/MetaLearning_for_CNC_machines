{
    "model_architecture": {
      "model_type": "LSTM_AE",
      "input_dim": "auto_calculated",
      "hidden_dim": 128,
      "latent_dim": 64,
      "num_layers": 2,
      "dropout_rate": 0.2
    },
    "training_parameters": {
      "learning_rate": 0.0001,
      "epochs": 100,
      "batch_size": 64,
      "train_ratio": 0.8,
      "early_stopping_patience": 20,
      "gradient_clip_max_norm": 1.0
    },
    "data_preprocessing": {
      "sequence_length": 333,
      "production_cycle": 333,
      "scaler_type": "MinMaxScaler",
      "scaler_range": [0, 1],
      "fill_na_method": "zero",
      "sequence_generation_method": "production_cycle"
    },
    "paths": {
      "train_data": "Data/M014_normal_processed.csv",
      "test_normal_data": "Data/M014_normal_processed.csv", 
      "test_anomaly_data": "Data/M014_faulty_processed.csv",
      "save_dir": "saved_models",
      "results_dir": "results"
    },
    "anomaly_detection": {
      "threshold_method": "statistical",
      "threshold_multiplier": 3,
      "threshold_base": "mean_plus_std"
    },
    "visualization_settings": {
      "figure_size": [12, 8],
      "dpi": 300,
      "font_size": 12,
      "save_format": "png"
    }
  }